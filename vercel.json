{
  "functions": {
    "api/swim-results.js": {
      "maxDuration": 60
    },
    "api/qualification.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/swim-results",
      "destination": "/api/swim-results.js"
    },
    {
      "source": "/api/qualification",
      "destination": "/api/qualification.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=()"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
